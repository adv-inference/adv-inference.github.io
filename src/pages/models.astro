---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Cluster Inventory | Adversarial Inference">
    <main class="flex-grow pt-24 pb-24 z-10 relative">
        <!-- Model Inventory Section -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-10 md:py-24 text-left">
            <div class="mb-12 md:mb-20">
                <h1 class="text-4xl sm:text-6xl lg:text-7xl font-bold mb-4 md:mb-6 uppercase tracking-tighter leading-tight text-white">Cluster Inventory</h1>
                <p class="text-ash font-mono text-sm md:text-lg uppercase tracking-wider md:tracking-[0.25em] text-white">Proprietary & Open-Source Abliterated Models.</p>
            </div>

            <!-- Proprietary Section -->
            <div class="mb-6 md:mb-8 text-left">
                <h2 class="text-lg md:text-2xl font-mono text-crimson uppercase tracking-widest border-b border-border pb-3 md:pb-4 inline-block md:block">Proprietary Core Models</h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 mb-16 md:mb-20">
                <!-- Proprietary Model 1 -->
                <div class="bg-surface border-2 border-crimson p-6 md:p-10 relative group shadow-[0_0_30px_rgba(217,0,0,0.1)] text-left">
                    <div class="absolute top-0 right-0 w-10 h-10 md:w-16 md:h-16 border-t-4 border-r-4 border-crimson"></div>
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 md:mb-8 gap-4 text-left">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold font-mono text-white mb-2 uppercase">ADV-CORE-30B</h3>
                            <span class="bg-crimson/10 text-crimson text-[10px] md:text-xs font-mono px-2 py-1 md:px-3 uppercase tracking-widest border border-crimson/20 font-bold">Primary Offensive LLM</span>
                        </div>
                        <div class="text-left md:text-right font-mono text-[10px] md:text-xs text-ash leading-relaxed">
                            STATUS: <span class="text-green-500 font-bold uppercase">Operational</span>
                        </div>
                    </div>
                    <p class="text-ash text-sm md:text-lg mb-6 md:mb-8 leading-relaxed text-white">
                        Our flagship model fine-tuned on offensive security operator workflows, red team logs, and exploit methodology.
                    </p>
                    <div class="font-mono text-xs md:text-sm border-t border-border pt-6 md:pt-8 text-left">
                        <div class="text-ash uppercase mb-1 md:mb-2 text-[9px] md:text-[10px] tracking-widest">Context Window</div>
                        <div class="text-white text-lg md:text-xl font-bold">64K Tokens</div>
                    </div>
                </div>

                <!-- Proprietary Model 2 -->
                <div class="bg-surface border border-border border-dashed p-6 md:p-10 relative group opacity-80 text-left">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 md:mb-8 gap-4 text-left">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold font-mono text-white mb-2 uppercase">ADV-CODE-108B</h3>
                            <span class="bg-white/5 text-ash text-[10px] md:text-xs font-mono px-2 py-1 md:px-3 uppercase tracking-widest border border-white/10 font-bold">Code & RE Specialist</span>
                        </div>
                        <div class="text-left md:text-right font-mono text-[10px] md:text-xs text-ash leading-relaxed">
                            STATUS: <span class="text-yellow-500 font-bold uppercase animate-pulse">Training</span>
                        </div>
                    </div>
                    <p class="text-ash text-sm md:text-lg mb-6 md:mb-8 leading-relaxed text-white text-left">
                        A high-parameter model specialized in reverse engineering, complex code auditing, and exploit drafting.
                    </p>
                    <div class="font-mono text-xs md:text-sm border-t border-border pt-6 md:pt-8 text-left">
                        <div class="text-ash uppercase mb-1 md:mb-2 text-[9px] md:text-[10px] tracking-widest">Context Window</div>
                        <div class="text-white text-lg md:text-xl font-bold">128K Tokens</div>
                    </div>
                </div>
            </div>

            <!-- Open Source Section -->
            <div class="mb-6 md:mb-8 text-left">
                <h2 class="text-lg md:text-2xl font-mono text-white uppercase tracking-widest border-b border-border pb-3 md:pb-4 inline-block md:block">Abliterated Open-Source</h2>
            </div>
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12">
                <!-- Open Source 1 -->
                <div class="bg-surface border border-border border-dashed p-6 md:p-10 relative group opacity-60 text-left">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 md:mb-8 gap-4 text-left">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold font-mono text-white mb-2 uppercase text-left">LLAMA-3-70B-ABL</h3>
                            <span class="bg-white/5 text-ash text-[10px] md:text-xs font-mono px-2 py-1 md:px-3 uppercase tracking-widest border border-white/10 font-bold">Community Abliterated</span>
                        </div>
                        <div class="text-left md:text-right font-mono text-[10px] md:text-xs text-ash leading-relaxed">
                            STATUS: <span class="text-ash font-bold uppercase">Coming Soon</span>
                        </div>
                    </div>
                    <p class="text-ash text-sm md:text-lg mb-6 md:mb-8 leading-relaxed text-left text-white">
                        A technical standard in open-weights abliteration. Meta's 70B model surgically stripped of safety constraints while preserving analytical power.
                    </p>
                    <div class="font-mono text-xs md:text-sm border-t border-border pt-6 md:pt-8 text-left">
                        <div class="text-ash uppercase mb-1 md:mb-2 text-[9px] md:text-[10px] tracking-widest">Context Window</div>
                        <div class="text-white text-lg md:text-xl font-bold">8K Tokens</div>
                    </div>
                </div>

                <!-- Open Source 2 -->
                <div class="bg-surface border border-border border-dashed p-6 md:p-10 relative group opacity-60 text-left">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-6 md:mb-8 gap-4 text-left">
                        <div>
                            <h3 class="text-2xl md:text-3xl font-bold font-mono text-white mb-2 uppercase">MIXTRAL-8X22B-UNC</h3>
                            <span class="bg-white/5 text-ash text-[10px] md:text-xs font-mono px-2 py-1 md:px-3 uppercase tracking-widest border border-white/10 font-bold">Community Uncensored</span>
                        </div>
                        <div class="text-left md:text-right font-mono text-[10px] md:text-xs text-ash leading-relaxed">
                            STATUS: <span class="text-ash font-bold uppercase">Coming Soon</span>
                        </div>
                    </div>
                    <p class="text-ash text-sm md:text-lg mb-6 md:mb-8 leading-relaxed text-left text-white">
                        The definitive MoE model for data-heavy operations. Uncensored and optimized to handle large context windows during multi-stage penetration tests.
                    </p>
                    <div class="font-mono text-xs md:text-sm border-t border-border pt-6 md:pt-8 text-left">
                        <div class="text-ash uppercase mb-1 md:mb-2 text-[9px] md:text-[10px] tracking-widest">Context Window</div>
                        <div class="text-white text-lg md:text-xl font-bold">64K Tokens</div>
                    </div>
                </div>
            </div>
        </section>
    </main>
</Layout>
