---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Stop fighting commercial safety filters. Get zero-telemetry access to abliterated, no-refusal models. Built for Red Teams and Security Researchers." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    
    <!-- OpenGraph / Social Meta Tags -->
    <meta property="og:title" content={title}>
    <meta property="og:description" content={description}>
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://adversarialinference.com">
    <meta name="theme-color" content="#D90000">

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke-width='2.5' stroke-linecap='butt' stroke-linejoin='miter'><circle cx='12' cy='12' r='8' stroke='%23D90000'/><line x1='8' y1='1' x2='16' y2='23' stroke='white'/></svg>">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body class="font-sans flex flex-col min-h-screen relative scanlines">

    <!-- Navigation -->
    <nav class="border-b border-border bg-black/90 backdrop-blur-sm fixed w-full top-0 z-40">
        <!-- Desktop Nav -->
        <div class="hidden md:flex max-w-[1440px] mx-auto px-10 h-20 items-center justify-between">
            <a href="/" class="flex items-center gap-4 hover:opacity-80 transition-opacity">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="butt" stroke-linejoin="miter" class="w-10 h-10 flex-shrink-0">
                    <circle cx="12" cy="12" r="8" class="stroke-crimson" />
                    <line x1="8" y1="1" x2="16" y2="23" stroke="white" />
                </svg>
                <span class="font-mono text-xl lg:text-2xl tracking-widest font-bold uppercase block text-white">Adversarial Inference</span>
            </a>
            <div class="flex items-center gap-10">
                <a href="/" class="text-base font-mono text-ash hover:text-white transition-colors uppercase tracking-widest">/Home</a>
                <a href="/models" class="text-base font-mono text-ash hover:text-white transition-colors uppercase tracking-widest">/Models</a>
                <a href="/methodology" class="text-base font-mono text-ash hover:text-white transition-colors uppercase tracking-widest">/Methodology</a>
                <a href="https://console.adversarialinference.com" class="text-base font-mono text-ash hover:text-white transition-colors uppercase tracking-widest" target="_blank">/Console</a>
                <a href="https://api.adversarialinference.com" class="text-base font-mono text-ash hover:text-white transition-colors uppercase tracking-widest" target="_blank">/API</a>
                <a href="/#pricing" class="bg-crimson hover:bg-crimson-hover text-white font-mono text-base px-8 py-3 uppercase tracking-widest transition-colors font-bold whitespace-nowrap">Request Access</a>
            </div>
        </div>

        <!-- Mobile Nav -->
        <div class="md:hidden flex h-16 items-center justify-between px-4 w-full">
            <!-- Left: Logo & Brand Text -->
            <a href="/" class="flex items-center gap-3 hover:opacity-80 transition-opacity z-10">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="butt" stroke-linejoin="miter" class="w-7 h-7 flex-shrink-0">
                    <circle cx="12" cy="12" r="8" class="stroke-crimson" />
                    <line x1="8" y1="1" x2="16" y2="23" stroke="white" />
                </svg>
                <span class="font-mono text-[13px] sm:text-base tracking-widest font-bold uppercase text-white">Adversarial Inference</span>
            </a>

            <!-- Right: Hamburger Menu -->
            <button id="mobile-menu-toggle" class="text-white p-2 z-10 flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
            </button>
        </div>
    </nav>

    <!-- Mobile Menu Overlay -->
    <div id="mobile-menu" class="fixed inset-0 bg-black/95 z-50 hidden flex-col items-center justify-center space-y-8 backdrop-blur-md">
        <button id="mobile-menu-close" class="absolute top-6 right-6 text-white p-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
        </button>
        <a href="/" class="mobile-link text-2xl font-mono text-white uppercase tracking-widest">/Home</a>
        <a href="/models" class="mobile-link text-2xl font-mono text-white uppercase tracking-widest">/Models</a>
        <a href="/methodology" class="mobile-link text-2xl font-mono text-white uppercase tracking-widest">/Methodology</a>
        <a href="https://console.adversarialinference.com" class="mobile-link text-2xl font-mono text-white uppercase tracking-widest" target="_blank">/Console</a>
        <a href="https://api.adversarialinference.com" class="mobile-link text-2xl font-mono text-white uppercase tracking-widest" target="_blank">/API</a>
        <a href="/#pricing" class="mobile-link text-2xl font-mono text-crimson font-bold uppercase tracking-widest">Request Access</a>
    </div>

    <script is:inline>
        const menuToggle = document.getElementById('mobile-menu-toggle');
        const menuClose = document.getElementById('mobile-menu-close');
        const mobileMenu = document.getElementById('mobile-menu');
        const mobileLinks = document.querySelectorAll('.mobile-link');

        function toggleMenu() {
            mobileMenu.classList.toggle('hidden');
            mobileMenu.classList.toggle('flex');
            document.body.classList.toggle('overflow-hidden');
        }

        if(menuToggle) menuToggle.addEventListener('click', toggleMenu);
        if(menuClose) menuClose.addEventListener('click', toggleMenu);
        mobileLinks.forEach(link => link.addEventListener('click', toggleMenu));
    </script>

    <slot />

    <!-- Footer -->
    <footer class="bg-gunmetal border-t border-border pt-16 md:pt-24 pb-12 z-10 relative">
        <div class="max-w-[1440px] mx-auto px-4 md:px-10">
            <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 mb-12 md:mb-20">
                
                <div>
                    <div class="flex items-center gap-3 md:gap-4 mb-6 md:mb-10 text-left">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="butt" stroke-linejoin="miter" class="w-8 h-8 md:w-10 md:h-10 flex-shrink-0">
                            <circle cx="12" cy="12" r="8" class="stroke-crimson" />
                            <line x1="8" y1="1" x2="16" y2="23" stroke="white" />
                        </svg>
                        <span class="font-mono text-base md:xl tracking-widest font-bold uppercase text-white">Adversarial Inference</span>
                    </div>
                    <p class="text-ash text-sm md:text-lg lg:text-xl max-w-lg leading-relaxed font-mono italic text-left">
                        Compute infrastructure built strictly for authorized B2B adversary emulation and security research.
                    </p>
                </div>

                <div class="flex flex-col md:items-end justify-start space-y-3 md:space-y-4 font-mono text-sm md:text-lg lg:text-xl">
                    <a href="mailto:adversarialinference@protonmail.com" class="text-ash hover:text-white transition-colors break-all">adversarialinference@protonmail.com</a>
                    <a href="/legal#tos" class="text-ash hover:text-white transition-colors uppercase tracking-widest text-xs md:text-sm">Terms of Service</a>
                    <a href="/legal#privacy" class="text-ash hover:text-white transition-colors uppercase tracking-widest text-xs md:text-sm">Privacy Policy</a>
                </div>
            </div>
            
            <div class="border-t border-border pt-8 md:pt-12 flex flex-col md:flex-row justify-between items-start md:items-center gap-4 text-xs md:text-sm lg:text-base text-ash/60 font-mono leading-relaxed">
                <div class="max-w-xl md:max-w-2xl lg:max-w-3xl pr-4 md:pr-8 text-left">
                    <p class="mb-4 md:mb-6">
                        Cancel anytime. Due to upfront GPU compute costs, we do not offer refunds on used API credits. Service is strictly for authorized B2B adversary emulation and security research.
                    </p>
                    <p>&copy; 2026 Adversarial Inference. All rights reserved.</p>
                </div>
                <div class="flex items-center gap-2">
                    <span class="relative flex h-3 w-3">
                      <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
                      <span class="relative inline-flex rounded-full h-3 w-3 bg-green-500"></span>
                    </span>
                    <span class="text-green-500 font-bold uppercase tracking-widest text-[10px] md:text-xs">API Status: All Systems Operational</span>
                </div>
            </div>
        </div>
    </footer>

</body>
</html>
