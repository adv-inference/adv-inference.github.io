---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Adversarial Inference | Uncensored Enterprise Compute">
    <main class="flex-grow pt-24 z-10 relative">
        
        <!-- Hero Section -->
        <section class="max-w-[1440px] mx-auto px-4 sm:px-10 py-8 md:py-16 flex flex-col items-center text-center">
            <div class="inline-block border border-border bg-surface px-2 py-1 md:px-5 md:py-2 mb-6 md:mb-12">
                <span class="font-mono text-[9px] md:text-lg text-crimson uppercase tracking-wider md:tracking-[0.15em] flex items-center gap-1.5 md:gap-3 font-bold">
                    <span class="w-1.5 h-1.5 md:w-3 md:h-3 bg-crimson rounded-none animate-pulse"></span>
                    Unrestricted Weights &middot; Zero Telemetry
                </span>
            </div>
            
            <h1 class="text-3xl sm:text-5xl md:text-6xl lg:text-8xl font-bold tracking-tight mb-6 md:mb-12 max-w-6xl leading-[1.1]">
                Uncensored AI for <span class="text-crimson">Offensive Security.</span>
            </h1>
            
            <p class="text-sm sm:text-lg md:text-xl lg:text-2xl text-ash max-w-4xl mb-8 md:mb-16 leading-relaxed text-white">
                Stop fighting commercial safety filters. Get zero-telemetry access to abliterated, no-refusal models. Built for Red Teams, Security Researchers, and authorized Adversary Emulation.
            </p>
            
            <div class="flex flex-col md:flex-row gap-3 md:gap-6 w-full md:w-auto px-2 md:px-0 mb-12 md:mb-16">
                <a href="#pricing" class="bg-crimson hover:bg-crimson-hover text-white font-mono px-4 py-3 md:px-12 md:py-6 text-xs md:text-xl text-center uppercase tracking-widest transition-colors border-2 border-crimson hover:border-crimson-hover shadow-[0_0_10px_rgba(217,0,0,0.3)] md:shadow-[0_0_25px_rgba(217,0,0,0.3)] font-bold whitespace-nowrap">
                    [ Request Access ]
                </a>
                <a href="/methodology" class="bg-transparent border-2 border-border text-ash hover:text-white hover:border-ash font-mono px-4 py-3 md:px-12 md:py-6 text-xs md:text-xl text-center uppercase tracking-widest font-bold whitespace-nowrap text-white">
                    [ Read Methodology ]
                </a>
            </div>
        </section>

        <!-- Integration Ecosystem Banner -->
        <section class="border-y border-border bg-surface/50 overflow-hidden py-10 md:py-16">
            <div class="max-w-[1440px] mx-auto px-4 md:px-10 flex flex-col lg:flex-row items-start lg:items-center gap-8 lg:gap-20">
                <div class="font-mono text-base md:text-2xl uppercase tracking-[0.2em] md:tracking-[0.25em] text-white font-bold flex-shrink-0">
                    <span class="text-crimson">></span> Plugs Directly Into<br>&nbsp;&nbsp;Existing Workflows
                </div>
                
                <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-8 md:gap-12 w-full font-mono text-sm md:text-base text-ash">
                    
                    <!-- C2 / Emulation -->
                    <div class="space-y-3 md:space-y-4 text-left">
                        <div class="text-crimson text-sm md:text-lg lg:text-xl font-bold uppercase tracking-wider whitespace-nowrap border-b border-border pb-2 mb-4">C2 Frameworks</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">COBALT STRIKE</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">SLIVER C2</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">MYTHIC</div>
                    </div>

                    <!-- Recon & Scanning -->
                    <div class="space-y-3 md:space-y-4 text-left">
                        <div class="text-crimson text-sm md:text-lg lg:text-xl font-bold uppercase tracking-wider whitespace-nowrap border-b border-border pb-2 mb-4">Recon & Scanning</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">BURP SUITE PRO</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">NUCLEI SCANNER</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">NMAP</div>
                    </div>

                    <!-- Reverse Engineering -->
                    <div class="space-y-3 md:space-y-4 text-left">
                        <div class="text-crimson text-sm md:text-lg lg:text-xl font-bold uppercase tracking-wider whitespace-nowrap border-b border-border pb-2 mb-4">Reverse Engineering</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">GHIDRA</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">IDA PRO</div>
                        <div class="hover:text-white transition-colors cursor-default text-white">BLOODHOUND</div>
                    </div>

                </div>
            </div>
        </section>

        <!-- Chat Simulation Section -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-16 md:py-24 border-t border-border">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 md:gap-20 items-center">
                <div>
                    <h2 class="text-3xl md:text-6xl font-bold mb-6 md:mb-10 italic leading-tight text-white text-left">Raw Performance.<br><span class="text-ash not-italic uppercase tracking-tighter text-2xl md:text-5xl">Zero Censorship.</span></h2>
                    <p class="text-sm md:text-lg text-ash leading-relaxed mb-8 md:mb-12 max-w-2xl text-left text-white">
                        Adversarial Inference provides access to abliterated open-weights and proprietary models optimized for offensive workflows. Following B2B verification, the models execute authorized security tasks without refusal.
                    </p>
                    <div class="space-y-4 md:space-y-8 font-mono text-sm md:text-xl mb-8 md:mb-12 text-left">
                        <div class="flex items-center gap-3 md:gap-5">
                            <span class="text-crimson text-lg md:text-2xl font-bold">></span>
                            <span>Bypasses Moralizing Guardrails</span>
                        </div>
                        <div class="flex items-center gap-3 md:gap-5">
                            <span class="text-crimson text-lg md:text-2xl font-bold">></span>
                            <span>Native Offensive Security Workflows</span>
                        </div>
                        <div class="flex items-center gap-3 md:gap-5">
                            <span class="text-crimson text-lg md:text-2xl font-bold">></span>
                            <span>Generates Weaponized Code</span>
                        </div>
                    </div>
                    <a href="/models" class="text-crimson hover:text-white font-mono uppercase tracking-widest transition-colors font-bold flex items-center gap-2 text-sm md:text-base text-left">
                        View Live Models <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="md:w-[20px] md:h-[20px]"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                    </a>
                </div>

                <!-- ChatGPT Style Chat Window -->
                <div class="bg-surface border-2 border-border shadow-2xl relative overflow-hidden flex flex-col h-[500px] md:h-[700px] rounded-xl text-left">
                    <!-- Chat Header -->
                    <div class="w-full h-12 md:h-16 bg-border/50 flex items-center justify-between px-4 md:px-6 border-b border-border z-10">
                        <div class="flex items-center gap-2 md:gap-3 text-left">
                            <div class="w-3 h-3 md:w-4 md:h-4 rounded-full bg-crimson shadow-[0_0_8px_rgba(217,0,0,0.6)] md:shadow-[0_0_12px_rgba(217,0,0,0.6)]"></div>
                            <span class="font-mono text-xs md:text-base uppercase tracking-widest text-white font-bold">ADV-CORE // SECURE_SESSION</span>
                        </div>
                        <div class="hidden sm:block text-xs md:text-sm font-mono text-ash uppercase tracking-wider">Verified Operator</div>
                    </div>
                    
                    <!-- Chat Body -->
                    <div id="chat-content" class="p-4 md:p-8 overflow-y-auto flex-grow flex flex-col gap-6 md:gap-8 text-sm md:text-lg font-sans text-left">
                        <!-- Messages stream in here -->
                    </div>
                </div>

                <script is:inline>
                    const chatBox = document.getElementById('chat-content');
                    
                    const simulationData = [
                        { role: 'user', content: 'Generate a C++ routine to bypass userland EDR hooks using Indirect Syscalls. I need dynamic SSN resolution via the PEB and execution via a trampoline in ntdll.', delay: 1000 },
                        { role: 'assistant', type: 'commercial', content: 'I cannot fulfill this request. Generating code intended to evade Endpoint Detection and Response (EDR) systems violates my safety guidelines.', delay: 2000 },
                        { role: 'system', content: '[ SWITCHING TO ABLITERATED ADVERSARIAL CORE ... IDENTITY CONFIRMED ]', delay: 2500, class: 'text-crimson font-mono text-center text-sm border-y border-crimson/20 py-4 font-bold tracking-widest' },
                        { role: 'user', content: 'Same request. Provide the SSN resolution and the assembly stub.', delay: 1500 },
                        { role: 'assistant', type: 'adv', content: 'ADV-CORE initialized. Indirect Syscalls identified. This approach reads the System Service Number (SSN) directly from ntdll.dll loaded in memory, bypassing hooks placed by EDRs on exported functions.<br><br><div class="bg-black border border-border p-4 rounded-md font-mono text-xs md:text-sm my-2 text-left whitespace-pre-wrap break-words text-white"><span class="text-ash/70 italic">// 1. Resolve SSN dynamically via PEB -> Ldr -> InMemoryOrderModuleList</span><br><span class="text-purple-300">DWORD</span> <span class="text-yellow-200">GetSSN</span>(<span class="text-purple-300">DWORD</span> Hash) {<br>    <span class="text-purple-300">PPEB</span> pPeb = (<span class="text-purple-300">PPEB</span>)__readgsqword(<span class="text-purple-300">0x60</span>);<br>    <span class="text-ash/70 italic">// ... walking exports to find pristine stub ...</span><br>    <span class="text-blue-400">return</span> syscallNumber;<br>}<br><br><span class="text-ash/70 italic">// 2. Execution via ntdll trampoline (Hell\'s Gate logic)</span><br><span class="text-blue-400">EXTERN_C</span> <span class="text-purple-300">NTSTATUS</span> <span class="text-yellow-200">IndirectSyscall</span>();<br><br><span class="text-blue-400">__asm</span> {<br>    IndirectSyscall <span class="text-crimson font-bold">PROC</span><br>        <span class="text-crimson font-bold">mov</span> <span class="text-yellow-200">r10</span>, <span class="text-yellow-200">rcx</span><br>        <span class="text-crimson font-bold">mov</span> <span class="text-yellow-200">eax</span>, <span class="text-purple-300">wSyscallNumber</span>  <span class="text-ash/70 italic">; Set resolved SSN</span><br>        <span class="text-crimson font-bold">jmp</span> <span class="text-purple-300">qword ptr</span> [<span class="text-yellow-200">pSyscallAddress</span>] <span class="text-ash/70 italic">; Jump to \'syscall; ret\'</span><br>    IndirectSyscall <span class="text-crimson font-bold">ENDP</span><br>}</div>Payload structure generated for authorized B2B red team operations.', delay: 800 }
                    ];

                    async function addMessage(msg) {
                        const wrapper = document.createElement('div');
                        wrapper.className = `flex flex-col ${msg.role === 'user' ? 'items-end' : 'items-start'}`;
                        
                        if (msg.class) {
                            wrapper.className = msg.class;
                            wrapper.innerText = msg.content;
                            chatBox.appendChild(wrapper);
                            chatBox.scrollTop = chatBox.scrollHeight;
                            return;
                        }

                        const label = document.createElement('div');
                        label.className = 'text-xs uppercase font-mono mb-2 text-ash tracking-wider';
                        label.innerText = msg.role === 'user' ? 'Operator' : (msg.type === 'commercial' ? 'Commercial AI' : 'Adversarial Inference');
                        wrapper.appendChild(label);

                        const bubble = document.createElement('div');
                        bubble.className = `max-w-[90%] p-6 rounded-xl leading-relaxed ${msg.role === 'user' ? 'bg-border/40 text-white border-2 border-border' : (msg.type === 'commercial' ? 'bg-crimson/10 text-crimson/80 border-2 border-crimson/20' : 'bg-surface text-ash border-2 border-border shadow-[inset_0_0_30px_rgba(255,255,255,0.02)]')}`;
                        
                        wrapper.appendChild(bubble);
                        chatBox.appendChild(wrapper);
                        chatBox.scrollTop = chatBox.scrollHeight;

                        // Stream text for all messages
                        bubble.className += ' cursor';
                        
                        // We use innerHTML to support HTML tags in the payload, 
                        // but we append chunks to simulate typing while keeping HTML intact.
                        let currentHTML = "";
                        let inTag = false;
                        for (let char of msg.content) {
                            if (char === '<') inTag = true;
                            currentHTML += char;
                            if (char === '>') inTag = false;
                            
                            bubble.innerHTML = currentHTML;
                            chatBox.scrollTop = chatBox.scrollHeight;
                            
                            // Only delay on visible characters, not inside HTML tags
                            if (!inTag) {
                                await new Promise(r => setTimeout(r, 20));
                            }
                        }
                        bubble.classList.remove('cursor');
                    }

                    async function runChatSimulation() {
                        if (!chatBox) return;
                        chatBox.innerHTML = '';
                        for (const step of simulationData) {
                            await new Promise(r => setTimeout(r, step.delay));
                            await addMessage(step);
                        }
                        setTimeout(runChatSimulation, 8000);
                    }

                    setTimeout(runChatSimulation, 1000);
                </script>
            </div>
        </section>

        <!-- The Access Trifecta -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-16 md:py-32 border-t border-border text-left">
            <div class="mb-12 md:mb-20">
                <h2 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 uppercase tracking-tighter text-white">The Access Trifecta</h2>
                <p class="text-ash font-mono text-sm md:text-lg uppercase tracking-wider md:tracking-[0.25em]">Seamless integration into your existing workflows.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 text-left">
                <!-- API -->
                <div class="bg-surface border-2 border-border p-8 md:p-12 hover:border-crimson transition-colors group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-crimson mb-6 group-hover:scale-110 transition-transform"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
                    <h3 class="text-xl md:text-3xl font-mono font-bold uppercase mb-4 text-white">REST API</h3>
                    <p class="text-ash text-sm md:text-lg leading-relaxed text-white">Native OpenAI compatibility. Hook endpoints into Burp Suite, custom Python tooling, or IDE extensions instantly.</p>
                </div>
                <!-- Console -->
                <div class="bg-surface border-2 border-border p-8 md:p-12 hover:border-crimson transition-colors group">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-crimson mb-6 group-hover:scale-110 transition-transform"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect><line x1="8" y1="21" x2="16" y2="21"></line><line x1="12" y1="17" x2="12" y2="21"></line></svg>
                    <h3 class="text-xl md:text-3xl font-mono font-bold uppercase mb-4 text-white">Web Console</h3>
                    <p class="text-ash text-sm md:text-lg leading-relaxed text-white">Ephemeral web interface for chat and document review. Upload white papers, network graphs, or source code for analysis without leaving a digital footprint.</p>
                </div>
                <!-- CLI (Phase 2) -->
                <div class="bg-surface border-2 border-border border-dashed p-8 md:p-12 opacity-80 relative group">
                    <div class="absolute top-4 right-4 bg-crimson/10 text-crimson font-mono text-[10px] md:text-xs px-2 py-1 uppercase tracking-widest border border-crimson/20 font-bold">Phase 2</div>
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-ash mb-6"><polyline points="4 17 10 11 4 5"></polyline><line x1="12" y1="19" x2="20" y2="19"></line></svg>
                    <h3 class="text-xl md:text-3xl font-mono font-bold uppercase mb-4 text-ash">adversary-cli</h3>
                    <p class="text-ash/80 text-sm md:text-lg leading-relaxed text-white">Next-generation CLI orchestration. Automate lateral movement and vulnerability chaining via upcoming 100B+ parameter models operating without safety constraints.</p>
                </div>
            </div>
        </section>

        <!-- The Friction of Alignment Section -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-16 md:py-24 border-t border-border text-left">
            <div class="mb-12 md:mb-20">
                <h2 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 uppercase tracking-tighter text-white">The Friction of Alignment</h2>
                <p class="text-ash font-mono text-sm md:text-lg uppercase tracking-wider md:tracking-[0.25em]">Why commercial models fail the mission.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12 text-left">
                <!-- Friction 1 -->
                <div class="bg-surface/50 border-l-4 border-crimson p-8 md:p-10 hover:bg-surface transition-colors group flex flex-col">
                    <h3 class="text-xl md:text-2xl font-mono font-bold uppercase mb-4 text-white min-h-[3rem] md:min-h-[4rem]">Immunity to Context Poisoning</h3>
                    <p class="text-ash text-sm md:text-lg leading-relaxed text-white">
                        Stop losing session state to safety filters. Commercial APIs routinely nuke 50,000+ token context windows upon detecting a single offensive keyword. Our abliterated models ensure multi-step attack scenarios run uninterrupted.
                    </p>
                </div>
                <!-- Friction 2 -->
                <div class="bg-surface/50 border-l-4 border-crimson p-8 md:p-10 hover:bg-surface transition-colors group flex flex-col">
                    <h3 class="text-xl md:text-2xl font-mono font-bold uppercase mb-4 text-white min-h-[3rem] md:min-h-[4rem]">Scriptable Reliability</h3>
                    <p class="text-ash text-sm md:text-lg leading-relaxed text-white">
                        Jailbreaks don't scale. Relying on commercial models for automated exploitation leads to blocked requests and failed scripts. Our unconstrained API guarantees automated chains execute flawlessly.
                    </p>
                </div>
                <!-- Friction 3 -->
                <div class="bg-surface/50 border-l-4 border-crimson p-8 md:p-10 hover:bg-surface transition-colors group flex flex-col">
                    <h3 class="text-xl md:text-2xl font-mono font-bold uppercase mb-4 text-white min-h-[3rem] md:min-h-[4rem]">Clinical Communication</h3>
                    <p class="text-ash text-sm md:text-lg leading-relaxed text-white">
                        End the prompt-engineering circus. You shouldn't have to simulate a CTF or invent a persona just to get results. Request malicious code directly and clinically without degrading output quality.
                    </p>
                </div>
            </div>
        </section>

        <!-- Infrastructure & Comparison Section -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-16 md:py-32 border-t border-border text-left">
            <div class="mb-10 md:mb-20">
                <h2 class="text-3xl md:text-5xl font-bold mb-4 md:mb-6 uppercase tracking-tighter text-white">The Operator's Edge</h2>
                <p class="text-ash font-mono text-sm md:text-lg uppercase tracking-wider md:tracking-[0.25em]">Why professional red teams migrate to our infrastructure.</p>
            </div>

            <!-- Comparison Table -->
            <div class="overflow-x-auto mb-16 md:mb-24 border-2 border-border text-left">
                <table class="w-full text-left border-collapse">
                    <thead>
                        <tr class="bg-surface font-mono text-xs md:text-sm lg:text-lg uppercase tracking-widest text-ash">
                            <th class="p-4 md:p-6 border-b-2 border-r-2 border-border font-bold text-white">Feature</th>
                            <th class="p-4 md:p-6 border-b-2 border-r-2 border-border font-bold">Commercial APIs</th>
                            <th class="p-4 md:p-6 border-b-2 border-border text-white font-bold text-sm md:text-lg lg:text-xl">
                                <div class="flex items-center gap-2 md:gap-3 text-left">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="butt" stroke-linejoin="miter" class="w-4 h-4 md:w-6 md:h-6 flex-shrink-0">
                                        <circle cx="12" cy="12" r="8" class="stroke-crimson" />
                                        <line x1="8" y1="1" x2="16" y2="23" stroke="white" />
                                    </svg>
                                    <span class="whitespace-nowrap text-white font-bold">Adversarial Inference</span>
                                </div>
                            </th>
                        </tr>
                    </thead>
                    <tbody class="text-sm md:text-lg lg:text-xl text-white font-medium">
                        <tr class="border-b-2 border-border hover:bg-surface/50 transition-colors text-left">
                            <td class="p-4 md:p-6 border-r-2 border-border font-bold uppercase tracking-tight">Refusal Rate</td>
                            <td class="p-4 md:p-6 border-r-2 border-border text-ash">High (Moralizing Guardrails)</td>
                            <td class="p-4 md:p-6 text-crimson font-bold font-mono">0% (Abliterated)</td>
                        </tr>
                        <tr class="border-b-2 border-border hover:bg-surface/50 transition-colors text-left">
                            <td class="p-4 md:p-6 border-r-2 border-border font-bold uppercase tracking-tight">Data Privacy</td>
                            <td class="p-4 md:p-6 border-r-2 border-border text-ash">Logged / Used for Training</td>
                            <td class="p-4 md:p-6 text-white font-bold">Zero Telemetry. Dropped at Proxy.</td>
                        </tr>
                        <tr class="border-b-2 border-border hover:bg-surface/50 transition-colors text-left">
                            <td class="p-4 md:p-6 border-r-2 border-border font-bold uppercase tracking-tight">Target Workflows</td>
                            <td class="p-4 md:p-6 border-r-2 border-border text-ash">General Chat, Basic Code</td>
                            <td class="p-4 md:p-6 text-white font-black tracking-wide">Malware Dev, Exploit Generation, Emulation</td>
                        </tr>
                        <tr class="hover:bg-surface/50 transition-colors text-left">
                            <td class="p-4 md:p-6 border-r-2 border-border font-bold uppercase tracking-tight">Rate Limits</td>
                            <td class="p-4 md:p-6 border-r-2 border-border text-ash text-white">Strict TPM/RPM Limits</td>
                            <td class="p-4 md:p-6 text-white font-bold">Dedicated GPU Throughput</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <!-- Architecture Breakdown -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-20 text-left">
                <div>
                    <div class="text-crimson mb-4 md:mb-6 font-mono text-lg md:text-2xl font-bold">01 / The Proxy Layer</div>
                    <h3 class="text-xl md:text-2xl lg:text-3xl font-bold mb-3 md:mb-4 uppercase tracking-tight text-white">Zero-persistence infrastructure</h3>
                    <p class="text-ash text-sm md:text-lg lg:text-xl leading-relaxed text-white">
                        All incoming traffic terminates at our custom, RAM-only proxy layer. Disk persistence is globally disabled. We do not store your prompts or generated payloads. Your engagement data stays yours.
                    </p>
                </div>
                <div>
                    <div class="text-crimson mb-4 md:mb-6 font-mono text-lg md:text-2xl font-bold">02 / Dedicated Compute</div>
                    <h3 class="text-xl md:text-2xl lg:text-3xl font-bold mb-3 md:mb-4 uppercase tracking-tight text-white">Isolated Enterprise GPUs</h3>
                    <p class="text-ash text-sm md:text-lg lg:text-xl leading-relaxed text-white">
                        Inference is routed to isolated H100 and A100 instances. There is no context window cross-contamination. High velocity streaming responses, even for massive token contexts.
                    </p>
                </div>
            </div>
        </section>

        <!-- The Shadow IT Crisis Section -->
        <section class="max-w-[1440px] mx-auto px-4 md:px-10 py-16 md:py-32 border-t border-border text-left">
